{
  "name": "educatr",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "varlock run -- bun --filter @educatr/web dev",
    "dev:mobile": "varlock run -- bun --filter @educatr/mobile start",
    "build": "varlock run -- bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:migrate": "varlock run -- bun --filter @educatr/db db:migrate",
    "db:generate": "bun --filter @educatr/db db:generate",
    "docker:up": "varlock run -- docker compose up",
    "docker:build": "varlock run -- docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@varlock/1password-plugin": "^0.3.5",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "varlock": "^0.9.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11"
}
