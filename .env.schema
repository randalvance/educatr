# @currentEnv=$APP_ENV
# @generateTypes(lang=ts, path=env.d.ts)
# @plugin(@varlock/1password-plugin)
# @initOp(token=$OP_TOKEN, allowAppAuth=forEnv(development))
# ---

# Application environment
# @required @type=enum(development, staging, production)
APP_ENV=development

# 1Password service account token (only needed in CI, not local dev)
# @optional @sensitive @type=string
OP_TOKEN=

# ===  OpenRouter  ===

# OpenRouter API key for chat, extraction, and embeddings
# @required @sensitive @type=string(minLength=1)
OPENROUTER_API_KEY=op("op://Development/OpenRouter API Key/credential")

# Per-task model overrides (optional). Leave unset to use gateway defaults.
# @optional @type=string
OPENROUTER_MODEL_CHAT=

# @optional @type=string
OPENROUTER_MODEL_EXTRACTION=

# @optional @type=string
OPENROUTER_MODEL_EMBEDDING=

# ===  Postgres  ===

# Connection string used by @educatr/db and apps/web.
# Default targets the docker-compose postgres from the host. Inside the
# compose network (migrate + web services) this is overridden to use the
# `postgres` service hostname — see docker-compose.yml.
# @required @sensitive @type=string(minLength=1)
DATABASE_URL=postgres://educatr:educatr@localhost:5432/educatr

# Tunable thresholds for topic deduplication / grouping (optional).
# @optional @type=number
TOPIC_DEDUP_THRESHOLD=

# @optional @type=number
TOPIC_RELATED_THRESHOLD=
