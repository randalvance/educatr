# Postgres connection string (server-only, never expose to clients).
# Used by packages/db and apps/web server code.
DATABASE_URL=postgres://user:password@host:5432/educatr

# OpenRouter API key (server-only). See https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional per-task model overrides (server-only).
OPENROUTER_MODEL_CHAT=
OPENROUTER_MODEL_EXTRACTION=
OPENROUTER_MODEL_EMBEDDING=

# Base URL for the web API. Used by apps/mobile at build/run time.
# Variables prefixed with EXPO_PUBLIC_ are inlined into the mobile bundle,
# so never put secrets here.
EXPO_PUBLIC_API_URL=http://localhost:3000
